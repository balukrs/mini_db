{
  "name": "mcp-store-db",
  "version": "0.1.0",
  "description": "A lightweight vector database and RAG storage layer for MCP servers. Supports document ingestion, chunking, embedding, and semantic search.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "dev": "npx tsx src/index.ts"
  },
  "keywords": [
    "vector",
    "embeddings",
    "rag",
    "mcp",
    "semantic-search",
    "document-store",
    "vector-database",
    "cosine-similarity"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/archiver": "^7.0.0",
    "@xenova/transformers": "^2.17.2",
    "archiver": "^7.0.1",
    "mime-types": "^3.0.2",
    "pdf-parse": "^2.4.5",
    "rtf-parser": "^1.3.3"
  }
}
